# gpt_signup_hybrid — config
# Copy thành .env rồi chỉnh giá trị.

# Max concurrent jobs (web UI multi mode). Giá trị 1-10, mặc định 2.
HYBRID_MAX_CONCURRENT=2

# Proxy cho Microsoft Graph API (refresh token + poll OTP).
# Để trống = direct (không proxy).
# Format: http://user:pass@host:port hoặc socks5://host:port
HYBRID_OUTLOOK_PROXY=

# Job timeout (giây). Phải > OTP timeout (180s). Mặc định 240.
HYBRID_JOB_TIMEOUT=240
